{
  "name": "keepkey-cli",
  "version": "0.1.0",
  "description": "KeepKey hardware wallet CLI — direct device access via HID/WebUSB",
  "type": "module",
  "bin": {
    "keepkey": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/keepkey",
    "test": "bun test __tests__/unit.test.ts",
    "test:live": "bun test __tests__/live-device.test.ts",
    "test:all": "bun test __tests__/"
  },
  "dependencies": {
    "@keepkey/hdwallet-core": "file:../../modules/hdwallet/packages/hdwallet-core",
    "@keepkey/hdwallet-keepkey": "file:../../modules/hdwallet/packages/hdwallet-keepkey",
    "@keepkey/hdwallet-keepkey-nodehid": "file:../../modules/hdwallet/packages/hdwallet-keepkey-nodehid",
    "@keepkey/hdwallet-keepkey-nodewebusb": "file:../../modules/hdwallet/packages/hdwallet-keepkey-nodewebusb",
    "node-hid": "^3.3.0",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": [
    "protobufjs",
    "tiny-secp256k1"
  ],
  "overrides": {
    "@keepkey/hdwallet-core": "file:../../modules/hdwallet/packages/hdwallet-core",
    "@keepkey/hdwallet-keepkey": "file:../../modules/hdwallet/packages/hdwallet-keepkey"
  }
}
